DISCORD_TOKEN=YOUR_DISCORD_TOKEN
GAME_API_KEY=YOUR_DREAMMS_API_KEY
GAME_API_BASE_URL=https://dreamms.gg/api/v1
DREAMBOT_ID=912628058375217163

FM_TAX_PERCENT=2
BUY_THRESHOLD_PERCENT=10
STRONG_BUY_THRESHOLD_PERCENT=20
SELL_THRESHOLD_PERCENT=10
STRONG_SELL_THRESHOLD_PERCENT=20

# Available styles:
# discord, minimal, compact, normal, full
EMBED_STYLE=discord

# Shows a private full-detail response when clicked.
# Ignored when EMBED_STYLE=full.
ENABLE_DETAILS_BUTTON=true

# OCR
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
OCR_LANGUAGE=eng
OCR_UPSCALE=2.5
OCR_MULTI_PASS=true
OCR_CLEANUP=true
OCR_MIN_PRICE=1000
OCR_MAX_PRICE=20000000000
